root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{yml,yaml,json}]
indent_size = 2

[*.cs]
# Treat nullable and reference-correctness issues as build-breaking.
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8625.severity = error
# Require SPDX file header.
dotnet_diagnostic.IDE0073.severity = error
file_header_template = SPDX-License-Identifier: GPL-2.0-only

# Strictness pass: dead private code is an error (removed, not tolerated).
dotnet_diagnostic.IDE0051.severity = error   # unused private member
dotnet_diagnostic.IDE0052.severity = error   # unread private member
# IDE0060 (unused parameter) is deliberately left at its default (suggestion), NOT error: the generator's
# emit-method families (EmitList/EmitHashSet/EmitStackQueue/…, and the collection-converter helpers) share a
# UNIFORM signature so the dispatch can call any of them interchangeably, and not every overload reads every
# parameter. Forcing IDE0060 would mean either dropping params that keep those signatures uniform or renaming
# them to `_` — both LESS readable than the named, self-documenting parameter. Strictness that degrades the code
# is not strictness worth having.
